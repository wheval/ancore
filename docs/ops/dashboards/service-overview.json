        {
          "expr": "sum by(job) (rate(http_requests_total{job=~\"$service\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
