echo "🔨 Running build..."
npx pnpm build || {
  echo "❌ Build failed. Please fix build errors before pushing."
  exit 1
}

echo "✅ Build successful!"

echo "🧪 Running tests..."
npx pnpm test || {
  echo "❌ Tests failed. Please fix failing tests before pushing."
  exit 1
}

echo "✅ All tests passed!"

echo "🔍 Running linter..."
npx pnpm lint || {
  echo "❌ Lint failed. Please fix lint errors before pushing."
  exit 1
}

echo "✅ Lint passed!"

echo "🎨 Checking formatting..."
npx pnpm format:check || {
  echo "❌ Format check failed. Run 'pnpm format' to fix formatting."
  exit 1
}

echo "✅ All checks passed! Pushing..."
